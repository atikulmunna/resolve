<?xml version="1.0" encoding="utf-8"?>
<!-- Resizable: the provider swaps between compact / wide / large layouts based
     on the size the user drags to (see ResolveWidgetProvider). Day count changes
     at most once a day, so a 30-min refresh + an app-side push is plenty. -->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="110dp"
    android:minHeight="110dp"
    android:minResizeWidth="110dp"
    android:minResizeHeight="110dp"
    android:maxResizeWidth="320dp"
    android:maxResizeHeight="320dp"
    android:targetCellWidth="4"
    android:targetCellHeight="2"
    android:updatePeriodMillis="1800000"
    android:initialLayout="@layout/widget_wide"
    android:previewLayout="@layout/widget_wide"
    android:previewImage="@mipmap/ic_launcher"
    android:description="@string/widget_description"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen" />
