<?xml version="1.0" encoding="utf-8"?>
<!-- 1c Stat block (4x4): name, big dial, full-width PANIC MODE pill. Text sizes
     scale with the widget in ResolveWidgetProvider. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/resolve_widget_bg"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="20dp">

    <TextView
        android:id="@+id/widget_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end"
        android:letterSpacing="0.1"
        android:text="RESOLVE"
        android:textColor="@color/widget_accent"
        android:textSize="12sp" />

    <FrameLayout
        android:id="@+id/widget_ring_box"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp">

        <ImageView
            android:id="@+id/widget_ring"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:contentDescription="@null" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/widget_days"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="0"
                android:textColor="@color/widget_ink"
                android:textSize="52sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_days_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.16"
                android:text="DAYS"
                android:textColor="@color/widget_muted"
                android:textSize="11sp" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/widget_panic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/panic_pill_bg"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="13dp"
        android:paddingBottom="13dp">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_lung"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/widget_panic_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:letterSpacing="0.12"
            android:text="PANIC MODE"
            android:textColor="@color/widget_accent"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
