<?xml version="1.0" encoding="utf-8"?>
<!-- 1b Dial (4x2): mini ring + streak + name + PANIC tap. Ring box + text sizes
     are overridden per widget size in ResolveWidgetProvider so it fills. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/resolve_widget_bg"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="14dp">

    <!-- Ring with the day number centred inside. -->
    <FrameLayout
        android:id="@+id/widget_ring_box"
        android:layout_width="76dp"
        android:layout_height="76dp">

        <ImageView
            android:id="@+id/widget_ring"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:contentDescription="@null" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/widget_days"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="0"
                android:textColor="@color/widget_ink"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_days_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.12"
                android:text="DAYS"
                android:textColor="@color/widget_muted"
                android:textSize="8sp" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="16dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_streak_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="0.12"
            android:text="CURRENT STREAK"
            android:textColor="@color/widget_accent"
            android:textSize="9sp" />

        <TextView
            android:id="@+id/widget_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="RESOLVE"
            android:textColor="@color/widget_ink"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/widget_panic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="9dp"
            android:background="@drawable/panic_pill_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="14dp"
            android:paddingTop="7dp"
            android:paddingBottom="7dp">

            <ImageView
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:src="@drawable/ic_lung"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/widget_panic_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:letterSpacing="0.1"
                android:text="PANIC"
                android:textColor="@color/widget_accent"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
